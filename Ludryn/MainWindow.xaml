<Window
    x:Class="Ludryn.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Ludryn">
    <Grid x:Name="RootGrid" Background="{StaticResource BaseBackgroundBrush}" KeyDown="Root_KeyDown"
          IsTabStop="True" XYFocusKeyboardNavigation="Enabled">
        <Frame x:Name="ContentFrame" CacheSize="4" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,34,56,0" Spacing="14">
            <Grid Width="42" Height="24" VerticalAlignment="Center">
                <Border Width="36" Height="20" CornerRadius="3" BorderBrush="{StaticResource PrimaryTextBrush}" BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="ControllerBatteryText" Text="--" Foreground="{StaticResource PrimaryTextBrush}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border Width="4" Height="10" CornerRadius="1" Background="{StaticResource PrimaryTextBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
            <TextBlock x:Name="ClockText" Text="19:34" Foreground="{StaticResource PrimaryTextBrush}" FontSize="22" FontWeight="SemiBold" />
        </StackPanel>

        <Grid VerticalAlignment="Bottom" Margin="0,0,0,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="104" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <Border Width="1120" Height="88" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="12" Background="#D51B1422" BorderBrush="#24FFFFFF" BorderThickness="1">
                <Grid ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="HomeTabButton" Grid.Column="0" Click="HomeTab_Click" Style="{StaticResource BottomTabButtonStyle}" IsTabStop="False">
                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="30" />
                            <TextBlock Text="Home" FontSize="18" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="LibraryTabButton" Grid.Column="1" Click="LibraryTab_Click" Style="{StaticResource BottomTabButtonStyle}" IsTabStop="False">
                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="30" />
                            <TextBlock Text="Biblioteca" FontSize="18" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="EmulatorsTabButton" Grid.Column="2" Click="EmulatorsTab_Click" Style="{StaticResource BottomTabButtonStyle}" IsTabStop="False">
                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="30" />
                            <TextBlock Text="Emuladores" FontSize="18" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SettingsTabButton" Grid.Column="3" Click="SettingsTab_Click" Style="{StaticResource BottomTabButtonStyle}" IsTabStop="False">
                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="30" />
                            <TextBlock Text="Configuracoes" FontSize="18" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="56,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="22">
                    <StackPanel x:Name="AcceptHint" Orientation="Horizontal" Spacing="8">
                        <Border Width="30" Height="30" CornerRadius="15" BorderBrush="#72EA49" BorderThickness="1"><TextBlock Text="A" Foreground="#72EA49" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" /></Border>
                        <TextBlock x:Name="AcceptHintText" Text="Selecionar" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel x:Name="XHint" Orientation="Horizontal" Spacing="8">
                        <Border Width="30" Height="30" CornerRadius="15" BorderBrush="#00A8FF" BorderThickness="1"><TextBlock Text="X" Foreground="#00A8FF" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" /></Border>
                        <TextBlock x:Name="XHintText" Text="Detalhes" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="22">
                    <StackPanel x:Name="YHint" Orientation="Horizontal" Spacing="8">
                        <Border Width="30" Height="30" CornerRadius="15" BorderBrush="#FFD32A" BorderThickness="1"><TextBlock Text="Y" Foreground="#FFD32A" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" /></Border>
                        <TextBlock x:Name="YHintText" Text="Procurar" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel x:Name="BackHint" Orientation="Horizontal" Spacing="8">
                        <Border Width="30" Height="30" CornerRadius="15" BorderBrush="#E84135" BorderThickness="1"><TextBlock Text="B" Foreground="#E84135" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" /></Border>
                        <TextBlock x:Name="BackHintText" Text="Voltar" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid x:Name="OptionsSideLayer" Visibility="Collapsed" Background="#7A000000">
            <Border Width="980" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="#EE0D0D12" BorderBrush="#3CFFFFFF" BorderThickness="1,0,0,0">
                <Grid Padding="34,44,34,38">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="OptionsPanelTitle" Text="Opções" Foreground="#F2C98E" FontFamily="Georgia" FontSize="42" FontWeight="Bold" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="OptionsPanelSubtitle" Grid.Row="1" Text="A Selecionar   B Voltar" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" Margin="0,8,0,24" />
                    <ScrollViewer x:Name="OptionsPanelScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Hidden">
                        <StackPanel x:Name="OptionsPanelContent" Spacing="12" />
                    </ScrollViewer>
                    <TextBlock Grid.Row="3" Text="Use o direcional para navegar" Foreground="{StaticResource SecondaryTextBrush}" FontSize="15" HorizontalAlignment="Center" Margin="0,22,0,0" />
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="ProfileSideLayer" Visibility="Collapsed" Background="#7A000000">
            <Border Width="620" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="#F20D0D12" BorderBrush="#3CFFFFFF" BorderThickness="1,0,0,0">
                <Grid Padding="40,54,40,42">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ProfilePanelTitle" Text="Perfil" Foreground="#F2C98E" FontFamily="Georgia" FontSize="42" FontWeight="Bold" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="ProfilePanelSubtitle" Grid.Row="1" Text="A Selecionar   B Voltar" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" Margin="0,8,0,28" TextWrapping="WrapWholeWords" />
                    <StackPanel x:Name="ProfilePanelContent" Grid.Row="2" Spacing="12" />
                    <TextBlock x:Name="ProfilePanelHint" Grid.Row="3" Text="View abre ou fecha este menu" Foreground="{StaticResource SecondaryTextBrush}" FontSize="15" HorizontalAlignment="Center" Margin="0,22,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
