<Page
    x:Class="Ludryn.Views.AddEmulatorSetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BaseBackgroundBrush}">
    <Grid Padding="120,86,120,178">
        <StackPanel Spacing="22" MaxWidth="980" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="Adicionar emulador" Foreground="#F2C98E" FontFamily="Georgia" FontSize="62" FontWeight="Bold" TextAlignment="Center" />
                <TextBlock Text="Escolha a plataforma, selecione o executavel e confirme com A." Foreground="{StaticResource SecondaryTextBrush}" FontSize="20" TextAlignment="Center" />
            </StackPanel>

            <Button x:Name="PlatformButton" Style="{StaticResource SettingsRowButtonStyle}" HorizontalAlignment="Stretch">
                <Grid Height="82" Padding="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="LT" Foreground="{StaticResource SecondaryTextBrush}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Plataforma" Foreground="{StaticResource SecondaryTextBrush}" FontSize="15" TextAlignment="Center" />
                        <TextBlock x:Name="PlatformText" Text="Nintendo Switch" Foreground="White" FontSize="28" FontWeight="SemiBold" TextAlignment="Center" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="RT" Foreground="{StaticResource SecondaryTextBrush}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" />
                </Grid>
            </Button>

            <Button x:Name="PickExecutableButton" Click="PickExecutable_Click" Style="{StaticResource SettingsRowButtonStyle}" HorizontalAlignment="Stretch">
                <Grid Height="98" Padding="24,0">
                    <StackPanel VerticalAlignment="Center" Spacing="5">
                        <TextBlock Text="Selecionar executavel" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock x:Name="ExecutableText" Text="Nenhum arquivo selecionado" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Button>

            <Button x:Name="ConfirmButton" Click="Confirm_Click" Style="{StaticResource SettingsRowButtonStyle}" HorizontalAlignment="Stretch">
                <Grid Height="82" Padding="24,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Confirmar" Foreground="White" FontSize="25" FontWeight="SemiBold" />
                        <TextBlock x:Name="ConfirmHintText" Text="Selecione um executavel para liberar a confirmacao." Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" />
                    </StackPanel>
                </Grid>
            </Button>

            <TextBlock Text="A Selecionar/Confirmar   B Voltar   LT/RT Plataforma   Cima/Baixo Opcoes" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
