<Page
    x:Class="Ludryn.Views.EmulatorsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Ludryn.Models"
    Background="{StaticResource BaseBackgroundBrush}">
    <Grid x:Name="PageRoot">
        <Border Height="650" VerticalAlignment="Top">
            <Grid>
            <Image x:Name="BackgroundArt" Width="{Binding ActualWidth, ElementName=PageRoot}" Height="650" Stretch="UniformToFill" Opacity="0.78" HorizontalAlignment="Center" VerticalAlignment="Top" />
            <Rectangle Fill="#70000000" />
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0.52" />
                        <GradientStop Color="#720D0D0F" Offset="0.72" />
                        <GradientStop Color="#D80D0D0F" Offset="0.9" />
                        <GradientStop Color="#FF0D0D0F" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            </Grid>
        </Border>

        <Grid Padding="72,70,72,178">
            <Grid.RowDefinitions>
                <RowDefinition Height="150" />
                <RowDefinition Height="*" />
                <RowDefinition Height="96" />
            </Grid.RowDefinitions>

            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="Emuladores" Foreground="#F2C98E" FontFamily="Georgia" FontSize="76" FontWeight="Bold" TextAlignment="Center" />
                <TextBlock x:Name="EmulatorSubtitle" Text="Sua coleção retro e multi-plataforma" Foreground="{StaticResource PrimaryTextBrush}" FontSize="22" TextAlignment="Center" Opacity="0.9" />
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer x:Name="SystemScrollViewer" VerticalAlignment="Stretch" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="SystemsPanel" Spacing="12" VerticalAlignment="Top">
                    <Button x:Name="Pcsx2Button" Tag="PlayStation 2" Click="EmulatorButton_Click" Style="{StaticResource EmulatorSideButtonStyle}">
                        <Grid ColumnSpacing="18" Width="270" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="Pcsx2Icon" Width="52" Height="52" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="PlayStation 2" Foreground="White" FontSize="23" />
                                <TextBlock x:Name="Pcsx2CountText" Text="0 jogos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="17" />
                            </StackPanel>
                        </Grid>
                    </Button>
                    <Button x:Name="YuzuButton" Tag="Nintendo Switch" Click="EmulatorButton_Click" Style="{StaticResource EmulatorSideButtonStyle}">
                        <Grid ColumnSpacing="18" Width="270" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="YuzuIcon" Width="52" Height="52" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Column="1"><TextBlock Text="Nintendo Switch" Foreground="White" FontSize="23" /><TextBlock x:Name="YuzuCountText" Text="0 jogos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="17" /></StackPanel>
                        </Grid>
                    </Button>
                    <Button x:Name="WiiButton" Tag="Wii" Click="EmulatorButton_Click" Style="{StaticResource EmulatorSideButtonStyle}">
                        <Grid ColumnSpacing="18" Width="270" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="WiiIcon" Width="52" Height="52" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Column="1"><TextBlock Text="Wii" Foreground="White" FontSize="23" /><TextBlock x:Name="WiiCountText" Text="0 jogos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="17" /></StackPanel>
                        </Grid>
                    </Button>
                    <Button x:Name="WiiUButton" Tag="Wii U" Click="EmulatorButton_Click" Style="{StaticResource EmulatorSideButtonStyle}">
                        <Grid ColumnSpacing="18" Width="270" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="WiiUIcon" Width="52" Height="52" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Column="1"><TextBlock Text="Wii U" Foreground="White" FontSize="23" /><TextBlock x:Name="WiiUCountText" Text="0 jogos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="17" /></StackPanel>
                        </Grid>
                    </Button>
                    <Button x:Name="RetroArchButton" Tag="Nintendo 64" Click="EmulatorButton_Click" Style="{StaticResource EmulatorSideButtonStyle}">
                        <Grid ColumnSpacing="18" Width="270" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="RetroArchIcon" Width="52" Height="52" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Column="1"><TextBlock Text="Nintendo 64" Foreground="White" FontSize="23" /><TextBlock x:Name="RetroArchCountText" Text="0 jogos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="17" /></StackPanel>
                        </Grid>
                    </Button>
                    <Button x:Name="Rpcs3Button" Tag="PlayStation 3" Click="EmulatorButton_Click" Style="{StaticResource EmulatorSideButtonStyle}">
                        <Grid ColumnSpacing="18" Width="270" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Grid Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="Rpcs3Icon" Width="52" Height="52" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Column="1"><TextBlock Text="PlayStation 3" Foreground="White" FontSize="23" /><TextBlock x:Name="Rpcs3CountText" Text="0 jogos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="17" /></StackPanel>
                        </Grid>
                    </Button>
                </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Column="1" Spacing="12" VerticalAlignment="Bottom">
                    <Grid>
                        <TextBlock x:Name="SelectedEmulatorTitle" Text="PlayStation 2  •  0 jogos" Foreground="{StaticResource PrimaryTextBrush}" FontSize="26" HorizontalAlignment="Left" />
                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                            <Border CornerRadius="6" BorderBrush="#CC44D7F2" BorderThickness="1.5" Padding="7,2">
                                <TextBlock Text="X" Foreground="#44D7F2" FontSize="14" FontWeight="Bold" />
                            </Border>
                            <TextBlock x:Name="SystemSortText" Text="Consoles: Mais recentes" Foreground="{StaticResource SecondaryTextBrush}" FontSize="18" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <ListView x:Name="EmulatorGamesList" SelectionMode="None" ItemContainerStyle="{StaticResource FlatListViewItemStyle}" Padding="0,20,0,0" ItemClick="Game_ItemClick" IsItemClickEnabled="True" GotFocus="List_GotFocus" ScrollViewer.HorizontalScrollBarVisibility="Hidden" XYFocusKeyboardNavigation="Enabled">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate><ItemsStackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Game">
                                <Grid x:Name="EmulatorGameSlot" GotFocus="Card_GotFocus" LostFocus="Card_LostFocus" IsTabStop="True" Width="350" Height="520" Margin="0,0,22,0">
                                    <Grid x:Name="EmulatorGameCard" Width="290" Height="435" VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                        <Grid.RenderTransform>
                                            <CompositeTransform ScaleX="1" ScaleY="1" TranslateY="0" />
                                        </Grid.RenderTransform>
                                        <Border x:Name="CardBorder" CornerRadius="16" BorderBrush="#2AFFFFFF" BorderThickness="1">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{x:Bind CoverArt, Mode=OneWay}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <Border CornerRadius="16" Background="#42000000" Margin="1" />
                                        <TextBlock Text="{x:Bind Title}" Visibility="{x:Bind CardTitleVisibility, Mode=OneWay}" Foreground="White" FontSize="26" FontWeight="Bold" TextAlignment="Center" TextWrapping="WrapWholeWords" VerticalAlignment="Center" Margin="20" />
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Border x:Name="EmptyStatePanel" Visibility="Collapsed" Margin="0,32,0,0" CornerRadius="16" Padding="28" Background="#B0101216" BorderBrush="#35FFFFFF" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Nenhuma ROM encontrada" Foreground="White" FontSize="28" FontWeight="SemiBold" />
                            <TextBlock Text="Pressione Y para configurar emuladores e diretórios de jogos." Foreground="{StaticResource SecondaryTextBrush}" FontSize="18" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="408,0,0,0" CornerRadius="10" Background="#BA101216" BorderBrush="#35FFFFFF" BorderThickness="1">
                <Grid Padding="28,14" ColumnSpacing="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="330" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <Image x:Name="InfoSystemIcon" Width="42" Height="42" Stretch="Uniform" />
                        <TextBlock x:Name="InfoSystemText" Text="PlayStation 2&#x0a;PS2" Foreground="White" FontSize="18" />
                    </StackPanel>
                    <TextBlock x:Name="InfoTotalGamesText" Grid.Column="1" Text="Total de jogos&#x0a;0" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" />
                    <TextBlock x:Name="InfoLastPlayedText" Grid.Column="2" Text="Título&#x0a;-" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" />
                    <TextBlock x:Name="InfoEmulatorText" Grid.Column="3" Text="Emulador&#x0a;Nenhum configurado" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" />
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="SystemSortOverlay" Visibility="Collapsed" Background="#B8000000" Canvas.ZIndex="100">
            <Border Width="560" Padding="32" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#F5121217" BorderBrush="#55FFFFFF" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock Text="Ordenar consoles" Foreground="#F2C98E" FontFamily="Georgia" FontSize="38" FontWeight="Bold" />
                    <TextBlock Text="Os jogos continuam sempre ordenados por recentes." Foreground="{StaticResource SecondaryTextBrush}" FontSize="17" Margin="0,0,0,8" />
                    <Button x:Name="SortSystemsRecentButton" Content="Mais recentes" Tag="Recent" Click="SystemSortButton_Click" Style="{StaticResource FilterPillButtonStyle}" HorizontalAlignment="Stretch" />
                    <Button x:Name="SortSystemsMostPlayedButton" Content="Mais jogados" Tag="MostPlayed" Click="SystemSortButton_Click" Style="{StaticResource FilterPillButtonStyle}" HorizontalAlignment="Stretch" />
                    <Button x:Name="SortSystemsAddedButton" Content="Recentemente adicionados" Tag="RecentlyAdded" Click="SystemSortButton_Click" Style="{StaticResource FilterPillButtonStyle}" HorizontalAlignment="Stretch" />
                    <TextBlock Text="A Confirmar    B Voltar" Foreground="{StaticResource SecondaryTextBrush}" FontSize="15" HorizontalAlignment="Center" Margin="0,10,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>


