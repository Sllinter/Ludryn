<Page
    x:Class="Ludryn.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Ludryn.Models"
    Background="{StaticResource BaseBackgroundBrush}">
    <Grid x:Name="PageRoot">
        <Border Height="650" VerticalAlignment="Top">
            <Grid>
            <Image x:Name="HeroBackground" Width="{Binding ActualWidth, ElementName=PageRoot}" Height="650" Stretch="UniformToFill" Opacity="0.88" HorizontalAlignment="Center" VerticalAlignment="Top" />
            <Rectangle Fill="#42000000" />
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0.52" />
                        <GradientStop Color="#660D0D0F" Offset="0.72" />
                        <GradientStop Color="#D80D0D0F" Offset="0.9" />
                        <GradientStop Color="#FF0D0D0F" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            </Grid>
        </Border>

        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="72,42,0,0" CornerRadius="18" Padding="16,8" Background="#9A090B10" BorderBrush="#24FFFFFF" BorderThickness="1">
            <TextBlock x:Name="ArtworkProgressText" Text="0/0 carregados" Foreground="{StaticResource SecondaryTextBrush}" FontSize="15" FontWeight="SemiBold" />
        </Border>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,82,0,0" Spacing="10">
            <Image x:Name="HeroLogo" Stretch="Uniform" MaxWidth="740" Height="150" Visibility="Collapsed" />
            <TextBlock x:Name="HeroTitle" Foreground="{StaticResource PrimaryTextBrush}" FontFamily="Georgia" FontSize="76" FontWeight="Bold" TextAlignment="Center" TextWrapping="WrapWholeWords" MaxWidth="980" />
            <Border HorizontalAlignment="Center" CornerRadius="22" Padding="16,8" Background="#A02D241A" BorderBrush="#30FFFFFF" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="30" Height="30" CornerRadius="15" Background="#2C2533">
                        <Image x:Name="HeroPlatformIcon" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock x:Name="HeroPlatformName" Text="Steam" Foreground="{StaticResource PrimaryTextBrush}" FontSize="18" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid VerticalAlignment="Bottom" Margin="80,0,0,178">
            <StackPanel Spacing="12">
                <TextBlock Text="Recentes" Foreground="{StaticResource PrimaryTextBrush}" FontSize="23" FontWeight="SemiBold" />
                <Border x:Name="EmptyStatePanel" Visibility="Collapsed" Width="660" CornerRadius="16" Padding="28" Background="#B0101216" BorderBrush="#35FFFFFF" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Nenhum jogo encontrado" Foreground="White" FontSize="28" FontWeight="SemiBold" />
                        <TextBlock Text="Instale jogos pela Steam/Epic ou configure emuladores e diretórios de ROMs." Foreground="{StaticResource SecondaryTextBrush}" FontSize="18" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
                <ListView x:Name="RecentList" ItemsSource="{x:Bind RecentGames}" SelectionMode="None" ItemContainerStyle="{StaticResource FlatListViewItemStyle}" Padding="0,24,0,0" HorizontalAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Hidden" XYFocusKeyboardNavigation="Enabled">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Game">
                            <Grid Width="350" Height="520" Margin="0,0,22,0">
                                <Button Style="{StaticResource GameCardButtonStyle}" Click="Game_Click" GotFocus="Game_GotFocus" LostFocus="Game_LostFocus" Width="290" Height="435" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button.RenderTransform>
                                        <CompositeTransform ScaleX="1" ScaleY="1" TranslateY="0" />
                                    </Button.RenderTransform>
                                    <Grid Width="290" Height="435" RenderTransformOrigin="0.5,0.5">
                                        <Grid.RenderTransform>
                                            <CompositeTransform ScaleX="1" ScaleY="1" TranslateY="0" />
                                        </Grid.RenderTransform>
                                        <Border CornerRadius="18" BorderBrush="#2AFFFFFF" BorderThickness="1">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{x:Bind CoverArt, Mode=OneWay}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <Border CornerRadius="18" Background="#45000000" Margin="1" />
                                        <TextBlock Text="{x:Bind Title}" Visibility="{x:Bind CardTitleVisibility, Mode=OneWay}" Foreground="White" TextAlignment="Center" TextWrapping="WrapWholeWords" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" Margin="20" />
                                    </Grid>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Grid>
    </Grid>
</Page>


