<Page
    x:Class="Ludryn.Views.AddRomDirectorySetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Ludryn.Models"
    Background="{StaticResource BaseBackgroundBrush}">
    <Grid Padding="120,76,120,178">
        <StackPanel Spacing="18" MaxWidth="1060" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="Adicionar pasta de ROMs" Foreground="#F2C98E" FontFamily="Georgia" FontSize="58" FontWeight="Bold" TextAlignment="Center" />
                <TextBlock Text="Escolha a plataforma, selecione a pasta e confirme os jogos encontrados." Foreground="{StaticResource SecondaryTextBrush}" FontSize="20" TextAlignment="Center" />
            </StackPanel>

            <Button x:Name="PlatformButton" Style="{StaticResource SettingsRowButtonStyle}" HorizontalAlignment="Stretch">
                <Grid Height="76" Padding="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="LT" Foreground="{StaticResource SecondaryTextBrush}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Plataforma" Foreground="{StaticResource SecondaryTextBrush}" FontSize="15" TextAlignment="Center" />
                        <TextBlock x:Name="PlatformText" Text="Nintendo Switch" Foreground="White" FontSize="27" FontWeight="SemiBold" TextAlignment="Center" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="RT" Foreground="{StaticResource SecondaryTextBrush}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" />
                </Grid>
            </Button>

            <Button x:Name="PickFolderButton" Click="PickFolder_Click" Style="{StaticResource SettingsRowButtonStyle}" HorizontalAlignment="Stretch">
                <Grid Height="88" Padding="24,0">
                    <StackPanel VerticalAlignment="Center" Spacing="5">
                        <TextBlock Text="Selecionar pasta" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock x:Name="FolderText" Text="Nenhuma pasta selecionada" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Button>

            <Border x:Name="LoadingPanel" Visibility="Collapsed" CornerRadius="16" Padding="22" Background="#A0101216" BorderBrush="#35FFFFFF" BorderThickness="1">
                <StackPanel Spacing="8">
                    <Border Width="42" Height="42" CornerRadius="21" BorderBrush="#CC52EB" BorderThickness="3" HorizontalAlignment="Center">
                        <TextBlock Text="..." Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-5,0,0" />
                    </Border>
                    <TextBlock Text="Carregando ROMs encontradas..." Foreground="White" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border x:Name="ResultsPanel" Visibility="Collapsed" CornerRadius="16" Padding="20" Background="#A0101216" BorderBrush="#35FFFFFF" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="ResultsTitleText" Text="0 jogos encontrados" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock x:Name="ResultsHintText" Text="Confira os jogos antes de confirmar." Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" />
                    <ItemsControl x:Name="PreviewGamesList" MaxHeight="210">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Game">
                                <TextBlock Text="{x:Bind Title}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="18" Margin="0,3" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Button x:Name="ConfirmButton" Click="Confirm_Click" Style="{StaticResource SettingsRowButtonStyle}" HorizontalAlignment="Stretch">
                <Grid Height="76" Padding="24,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Confirmar" Foreground="White" FontSize="25" FontWeight="SemiBold" />
                        <TextBlock x:Name="ConfirmHintText" Text="Selecione uma pasta para carregar os jogos." Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" />
                    </StackPanel>
                </Grid>
            </Button>

            <TextBlock Text="A Selecionar/Confirmar   B Voltar   LT/RT Plataforma   Cima/Baixo Opcoes" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
