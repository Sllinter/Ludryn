<Page
    x:Class="Ludryn.Views.GameDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BaseBackgroundBrush}">
    <Grid x:Name="PageRoot">
        <Border Height="720" VerticalAlignment="Top">
            <Grid>
            <Image x:Name="HeroArt" Width="{Binding ActualWidth, ElementName=PageRoot}" Height="720" Stretch="UniformToFill" Opacity="0.9" HorizontalAlignment="Center" VerticalAlignment="Top" />
            <Rectangle Fill="#58000000" />
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0.54" />
                        <GradientStop Color="#700D0D0F" Offset="0.72" />
                        <GradientStop Color="#D80D0D0F" Offset="0.9" />
                        <GradientStop Color="#FF0D0D0F" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            </Grid>
        </Border>

        <Grid x:Name="DetailLayout" Padding="170,122,120,184" ColumnSpacing="42">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="CoverContainer" Grid.ColumnSpan="2" Width="430" Height="645" CornerRadius="18" BorderBrush="#E65FF1FF" BorderThickness="2" Background="#151015" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <Grid>
                    <Image x:Name="CoverArt" Stretch="UniformToFill" Margin="2" />
                    <Rectangle Fill="#14000000" Margin="2" />
                    <TextBlock x:Name="CoverTitle" Foreground="White" TextAlignment="Center" TextWrapping="WrapWholeWords" FontFamily="Georgia" FontSize="42" FontWeight="Bold" VerticalAlignment="Top" Margin="30,58,30,0" />
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="940" Spacing="22">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <Image x:Name="TitleLogo" Stretch="Uniform" MaxWidth="760" Height="190" Visibility="Collapsed" />
                    <TextBlock x:Name="TitleText" Foreground="#F2C98E" FontFamily="Georgia" FontSize="92" FontWeight="Bold" TextAlignment="Center" TextWrapping="WrapWholeWords" MaxLines="2" />
                </StackPanel>

                <Button x:Name="PlayButton" Click="PlayButton_Click" Style="{StaticResource GameCardButtonStyle}" HorizontalAlignment="Center" Margin="0,12,0,0" Padding="0" CornerRadius="14">
                    <Border Width="560" Height="118" CornerRadius="14" Background="#8B61236B" BorderBrush="#D65FF1FF" BorderThickness="2">
                        <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="58" Height="58" CornerRadius="29" BorderBrush="White" BorderThickness="3">
                                <FontIcon Glyph="&#xE768;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock x:Name="PlayButtonText" Text="Iniciar jogo" Foreground="White" FontSize="44" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,18,0,0">
                    <Border Width="270" Height="86" CornerRadius="10" Background="#A20D1114" BorderBrush="#35FFFFFF" BorderThickness="1">
                        <Grid Padding="22,12" ColumnSpacing="16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="48" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Image x:Name="DetailPlatformIcon" Width="38" Height="38" Stretch="Uniform" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Plataforma" Foreground="{StaticResource SecondaryTextBrush}" FontSize="15" />
                                <TextBlock x:Name="PlatformText" Foreground="White" FontSize="23" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>


