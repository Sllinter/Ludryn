<Page
    x:Class="Ludryn.Views.EmulatorSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BaseBackgroundBrush}">
    <Grid Padding="120,76,120,158">
        <StackPanel Spacing="24" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="1180">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="Configurar emuladores" Foreground="#F2C98E" FontFamily="Georgia" FontSize="64" FontWeight="Bold" TextAlignment="Center" />
                <TextBlock Text="Adicione, visualize ou remova emuladores e pastas de ROMs usando o controle." Foreground="{StaticResource SecondaryTextBrush}" FontSize="20" TextAlignment="Center" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="26" Width="1040">
                <Button x:Name="AddEmulatorButton" Click="AddEmulator_Click" Width="507" Height="214" Padding="0" Style="{StaticResource SettingsRowButtonStyle}">
                    <Grid Padding="26,24">
                        <StackPanel VerticalAlignment="Center" Spacing="9">
                            <TextBlock Text="Adicionar emulador" Foreground="White" FontSize="28" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="Escolha a plataforma e depois o executavel do emulador." Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" TextWrapping="WrapWholeWords" MaxLines="2" />
                            <TextBlock x:Name="EmulatorCountText" Text="0 emulador(es) configurado(s)" Foreground="{StaticResource SecondaryTextBrush}" FontSize="15" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Button>

                <Button x:Name="AddRomDirectoryButton" Click="AddRomDirectory_Click" Width="507" Height="214" Padding="0" Style="{StaticResource SettingsRowButtonStyle}">
                    <Grid Padding="26,24">
                        <StackPanel VerticalAlignment="Center" Spacing="9">
                            <TextBlock Text="Adicionar pasta de ROMs" Foreground="White" FontSize="28" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="Escolha a plataforma e depois a pasta onde os jogos ficam." Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" TextWrapping="WrapWholeWords" MaxLines="2" />
                            <TextBlock x:Name="RomDirectoryCountText" Text="0 pasta(s) de ROMs configurada(s)" Foreground="{StaticResource SecondaryTextBrush}" FontSize="15" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Button>
            </StackPanel>

            <Grid ColumnSpacing="24" Width="1040">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border CornerRadius="14" Padding="20" Background="#A0101216" BorderBrush="#35FFFFFF" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Emuladores configurados" Foreground="White" FontSize="25" FontWeight="SemiBold" />
                        <TextBlock Text="Selecione um item para remover da Ludryn." Foreground="{StaticResource SecondaryTextBrush}" FontSize="15" />
                        <StackPanel x:Name="ConfiguredEmulatorsPanel" Spacing="10" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="14" Padding="20" Background="#A0101216" BorderBrush="#35FFFFFF" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Pastas de ROMs" Foreground="White" FontSize="25" FontWeight="SemiBold" />
                        <TextBlock Text="Selecione um item para parar de carregar essa pasta." Foreground="{StaticResource SecondaryTextBrush}" FontSize="15" />
                        <StackPanel x:Name="ConfiguredRomDirectoriesPanel" Spacing="10" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="A Selecionar/Remover   B Voltar   Direcional Navegar" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
